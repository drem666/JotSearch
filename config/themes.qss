   JotSearch — MidGrey Theme
   ═══════════════════════════════════════════════════ */

QMainWindow, QWidget {
    background-color: #2f2f2f;
    color: #e0e0e0;
    font-family: "Segoe UI", "SF Pro Text", sans-serif;
    font-size: 13px;
}

QMenuBar {
    background-color: #292929;
    color: #e0e0e0;
    border-bottom: 1px solid #454545;
    padding: 2px 0;
}

QMenuBar::item {
    background: transparent;
    padding: 4px 10px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #454545;
}

QMenu {
    background-color: #2f2f2f;
    color: #e0e0e0;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 4px;
}

QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #454545;
}

QTabWidget::pane {
    border: 1px solid #454545;
    border-radius: 6px;
    background-color: #2f2f2f;
}

QTabBar::tab {
    background-color: #292929;
    color: #bcbcbc;
    padding: 8px 20px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 2px;
    border: 1px solid #454545;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #2f2f2f;
    color: #ffffff;
    border-bottom: 2px solid #4f8cff;
}

QTabBar::tab:hover:!selected {
    background-color: #3a3a3a;
    color: #ffffff;
}

QGroupBox {
    border: 1px solid #454545;
    border-radius: 8px;
    margin-top: 12px;
    padding: 8px;
    font-weight: bold;
    color: #4f8cff;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 6px;
    color: #4f8cff;
}

QTextEdit, QLineEdit {
    background-color: #292929;
    color: #e0e0e0;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 6px;
    selection-background-color: #555555;
}

QTextEdit:focus, QLineEdit:focus {
    border: 1px solid #4f8cff;
}

QComboBox {
    background-color: #3a3a3a;
    color: #e0e0e0;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 4px 10px;
    min-height: 24px;
}

QComboBox:hover {
    border: 1px solid #4f8cff;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox QAbstractItemView {
    background-color: #2f2f2f;
    color: #e0e0e0;
    border: 1px solid #555555;
    selection-background-color: #454545;
}

QCheckBox {
    color: #e0e0e0;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid #555555;
    background-color: #292929;
}

QCheckBox::indicator:checked {
    background-color: #4f8cff;
    border-color: #4f8cff;
}

QCheckBox::indicator:indeterminate {
    background-color: #9e9e9e;
    border-color: #9e9e9e;
}

QRadioButton {
    color: #e0e0e0;
    spacing: 8px;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border: 1px solid #555555;
    background-color: #292929;
}

QRadioButton::indicator:checked {
    background-color: #4f8cff;
    border-color: #4f8cff;
}

QPushButton {
    background-color: #3a3a3a;
    color: #e0e0e0;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: 500;
    min-height: 28px;
}

QPushButton:hover {
    background-color: #454545;
    border-color: #4f8cff;
}

QPushButton:pressed {
    background-color: #292929;
}

QPushButton#btn_search {
    background-color: #4f8cff;
    color: #ffffff;
    font-weight: bold;
    border: none;
}

QPushButton#btn_search:hover {
    background-color: #6aa0ff;
}

QPushButton#btn_clear {
    background-color: #d96b6b;
    color: #ffffff;
    border: none;
}

QPushButton#btn_clear:hover {
    background-color: #e28a8a;
}

QPushButton#btn_new {
    background-color: #7ecb7e;
    color: #ffffff;
    border: none;
}

QPushButton#btn_new:hover {
    background-color: #98dc98;
}

QPushButton#btn_open {
    background-color: #4f8cff;
    color: #ffffff;
    border: none;
}

QPushButton#btn_open:hover {
    background-color: #6aa0ff;
}

QPushButton#btn_save {
    background-color: #e0c36f;
    color: #1c1c1c;
    border: none;
}

QPushButton#btn_save:hover {
    background-color: #edd48d;
}

QPushButton#btn_saveas {
    background-color: #e89b6b;
    color: #1c1c1c;
    border: none;
}

QPushButton#btn_saveas:hover {
    background-color: #f0b38c;
}

QToolButton {
    background-color: #3a3a3a;
    color: #e0e0e0;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 4px 10px;
}

QToolButton:hover {
    background-color: #454545;
}

QLabel {
    color: #e0e0e0;
}

QStatusBar {
    background-color: #292929;
    color: #bcbcbc;
    border-top: 1px solid #454545;
}

QScrollBar:vertical {
    background: #292929;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #555555;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #4f8cff;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background: #292929;
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #555555;
    border-radius: 5px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background: #4f8cff;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

QTreeWidget {
    background-color: #292929;
    color: #e0e0e0;
    border: 1px solid #555555;
    border-radius: 6px;
}

QTreeWidget::item:selected {
    background-color: #454545;
}

QTreeWidget::item:hover {
    background-color: #3a3a3a;
}

QHeaderView::section {
    background-color: #3a3a3a;
    color: #4f8cff;
    padding: 4px;
    border: 1px solid #555555;
}

QSpinBox {
    background-color: #292929;
    color: #e0e0e0;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 4px;
}

QDialog {
    background-color: #2f2f2f;
    color: #e0e0e0;
}

QDialogButtonBox QPushButton {
    min-width: 80px;
}
/*Theme End*/
