QMenuBar::item {
    background: transparent;
    padding: 4px 10px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #cbb99b;
}

QMenu {
    background-color: #f4ecd8;
    color: #5b4636;
    border: 1px solid #cbb99b;
    border-radius: 6px;
    padding: 4px;
}

QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #cbb99b;
}

QTabWidget::pane {
    border: 1px solid #cbb99b;
    border-radius: 6px;
    background-color: #f4ecd8;
}

QTabBar::tab {
    background-color: #e8d9c0;
    color: #5b4636;
    padding: 8px 20px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 2px;
    border: 1px solid #cbb99b;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #f4ecd8;
    color: #5b4636;
    border-bottom: 2px solid #b38b6d;
}

QTabBar::tab:hover:!selected {
    background-color: #dcc9b0;
    color: #5b4636;
}

QGroupBox {
    border: 1px solid #cbb99b;
    border-radius: 8px;
    margin-top: 12px;
    padding: 8px;
    font-weight: bold;
    color: #b38b6d;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 6px;
    color: #b38b6d;
}

QTextEdit, QLineEdit {
    background-color: #fff9e6;
    color: #5b4636;
    border: 1px solid #cbb99b;
    border-radius: 6px;
    padding: 6px;
    selection-background-color: #dcc9b0;
}

QTextEdit:focus, QLineEdit:focus {
    border: 1px solid #b38b6d;
}

QComboBox {
    background-color: #e8d9c0;
    color: #5b4636;
    border: 1px solid #cbb99b;
    border-radius: 6px;
    padding: 4px 10px;
    min-height: 24px;
}

QComboBox:hover {
    border: 1px solid #b38b6d;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox QAbstractItemView {
    background-color: #f4ecd8;
    color: #5b4636;
    border: 1px solid #cbb99b;
    selection-background-color: #cbb99b;
}

QCheckBox {
    color: #5b4636;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid #cbb99b;
    background-color: #fff9e6;
}

QCheckBox::indicator:checked {
    background-color: #b38b6d;
    border-color: #b38b6d;
}

QCheckBox::indicator:indeterminate {
    background-color: #cba6f7;
    border-color: #cba6f7;
}

QRadioButton {
    color: #5b4636;
    spacing: 8px;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border: 1px solid #cbb99b;
    background-color: #fff9e6;
}

QRadioButton::indicator:checked {
    background-color: #b38b6d;
    border-color: #b38b6d;
}

QPushButton {
    background-color: #e8d9c0;
    color: #5b4636;
    border: 1px solid #cbb99b;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: 500;
    min-height: 28px;
}

QPushButton:hover {
    background-color: #dcc9b0;
    border-color: #b38b6d;
}

QPushButton:pressed {
    background-color: #cbb99b;
}

QPushButton#btn_search {
    background-color: #b38b6d;
    color: #f4ecd8;
    font-weight: bold;
    border: none;
}

QPushButton#btn_search:hover {
    background-color: #c4a184;
}

QPushButton#btn_clear {
    background-color: #d32f2f;
    color: #f4ecd8;
    border: none;
}

QPushButton#btn_clear:hover {
    background-color: #f44336;
}

QPushButton#btn_new {
    background-color: #b38b6d;
    color: #f4ecd8;
    border: none;
}

QPushButton#btn_new:hover {
    background-color: #c4a184;
}

QPushButton#btn_open {
    background-color: #b38b6d;
    color: #f4ecd8;
    border: none;
}

QPushButton#btn_open:hover {
    background-color: #c4a184;
}

QPushButton#btn_save {
    background-color: #ffb74d;
    color: #f4ecd8;
    border: none;
}

QPushButton#btn_save:hover {
    background-color: #ffa726;
}

QPushButton#btn_saveas {
    background-color: #ff9800;
    color: #f4ecd8;
    border: none;
}

QPushButton#btn_saveas:hover {
    background-color: #fb8c00;
}

QToolButton {
    background-color: #e8d9c0;
    color: #5b4636;
    border: 1px solid #cbb99b;
    border-radius: 6px;
    padding: 4px 10px;
}

QToolButton:hover {
    background-color: #dcc9b0;
    border-color: #b38b6d;
}

QLabel {
    color: #5b4636;
}

QStatusBar {
    background-color: #e8d9c0;
    color: #5b4636;
    border-top: 1px solid #cbb99b;
}

QScrollBar:vertical {
    background: #e8d9c0;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #cbb99b;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #b38b6d;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background: #e8d9c0;
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #cbb99b;
    border-radius: 5px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background: #b38b6d;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

QTreeWidget {
    background-color: #fff9e6;
    color: #5b4636;
    border: 1px solid #cbb99b;
    border-radius: 6px;
}

QTreeWidget::item:selected {
    background-color: #cbb99b;
}

QTreeWidget::item:hover {
    background-color: #dcc9b0;
}

QHeaderView::section {
    background-color: #e8d9c0;
    color: #b38b6d;
    padding: 4px;
    border: 1px solid #cbb99b;
}

QSpinBox {
    background-color: #fff9e6;
    color: #5b4636;
    border: 1px solid #cbb99b;
    border-radius: 6px;
    padding: 4px;
}

QDialog {
    background-color: #f4ecd8;
    color: #5b4636;
}

QDialogButtonBox QPushButton {
    min-width: 80px;
}
/*Theme End*/