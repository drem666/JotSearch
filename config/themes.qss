    color: #e6f4ea;
    border: 1px solid #3f5f4c;
    border-radius: 6px;
    padding: 4px;
}

QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #2f4739;
}

QTabWidget::pane {
    border: 1px solid #2f4739;
    border-radius: 6px;
    background-color: #1b2a21;
}

QTabBar::tab {
    background-color: #16231b;
    color: #a7f3d0;
    padding: 8px 20px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 2px;
    border: 1px solid #2f4739;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #1b2a21;
    color: #ffffff;
    border-bottom: 2px solid #34d399;
}

QTabBar::tab:hover:!selected {
    background-color: #2f4739;
    color: #ffffff;
}

QGroupBox {
    border: 1px solid #2f4739;
    border-radius: 8px;
    margin-top: 12px;
    padding: 8px;
    font-weight: bold;
    color: #34d399;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 6px;
    color: #34d399;
}

QTextEdit, QLineEdit {
    background-color: #16231b;
    color: #e6f4ea;
    border: 1px solid #3f5f4c;
    border-radius: 6px;
    padding: 6px;
    selection-background-color: #2f4739;
}

QTextEdit:focus, QLineEdit:focus {
    border: 1px solid #34d399;
}

QComboBox {
    background-color: #2f4739;
    color: #ffffff;
    border: 1px solid #3f5f4c;
    border-radius: 6px;
    padding: 4px 10px;
    min-height: 24px;
}

QComboBox:hover {
    border: 1px solid #34d399;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox QAbstractItemView {
    background-color: #1b2a21;
    color: #e6f4ea;
    border: 1px solid #3f5f4c;
    selection-background-color: #2f4739;
}

QCheckBox {
    color: #e6f4ea;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid #3f5f4c;
    background-color: #16231b;
}

QCheckBox::indicator:checked {
    background-color: #34d399;
    border-color: #34d399;
}

QCheckBox::indicator:indeterminate {
    background-color: #6ee7b7;
    border-color: #6ee7b7;
}

QRadioButton {
    color: #e6f4ea;
    spacing: 8px;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border: 1px solid #3f5f4c;
    background-color: #16231b;
}

QRadioButton::indicator:checked {
    background-color: #34d399;
    border-color: #34d399;
}

QPushButton {
    background-color: #2f4739;
    color: #ffffff;
    border: 1px solid #3f5f4c;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: 500;
    min-height: 28px;
}

QPushButton:hover {
    background-color: #3f5f4c;
    border-color: #34d399;
}

QPushButton:pressed {
    background-color: #16231b;
}

QPushButton#btn_search {
    background-color: #34d399;
    color: #16231b;
    font-weight: bold;
    border: none;
}

QPushButton#btn_search:hover {
    background-color: #6ee7b7;
}

QPushButton#btn_clear {
    background-color: #dc2626;
    color: #ffffff;
    border: none;
}

QPushButton#btn_clear:hover {
    background-color: #ef4444;
}

QPushButton#btn_new {
    background-color: #059669;
    color: #ffffff;
    border: none;
}

QPushButton#btn_new:hover {
    background-color: #10b981;
}

QPushButton#btn_open {
    background-color: #047857;
    color: #ffffff;
    border: none;
}

QPushButton#btn_open:hover {
    background-color: #059669;
}

QPushButton#btn_save {
    background-color: #ca8a04;
    color: #ffffff;
    border: none;
}

QPushButton#btn_save:hover {
    background-color: #eab308;
}

QPushButton#btn_saveas {
    background-color: #d97706;
    color: #ffffff;
    border: none;
}

QPushButton#btn_saveas:hover {
    background-color: #f59e0b;
}

QToolButton {
    background-color: #2f4739;
    color: #ffffff;
    border: 1px solid #3f5f4c;
    border-radius: 6px;
    padding: 4px 10px;
}

QToolButton:hover {
    background-color: #3f5f4c;
}

QLabel {
    color: #e6f4ea;
}

QStatusBar {
    background-color: #16231b;
    color: #a7f3d0;
    border-top: 1px solid #2f4739;
}

QScrollBar:vertical {
    background: #16231b;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #3f5f4c;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #34d399;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background: #16231b;
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #3f5f4c;
    border-radius: 5px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background: #34d399;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

QTreeWidget {
    background-color: #16231b;
    color: #e6f4ea;
    border: 1px solid #3f5f4c;
    border-radius: 6px;
}

QTreeWidget::item:selected {
    background-color: #2f4739;
}

QTreeWidget::item:hover {
    background-color: #22352a;
}

QHeaderView::section {
    background-color: #2f4739;
    color: #34d399;
    padding: 4px;
    border: 1px solid #3f5f4c;
}

QSpinBox {
    background-color: #16231b;
    color: #e6f4ea;
    border: 1px solid #3f5f4c;
    border-radius: 6px;
    padding: 4px;
}

QDialog {
    background-color: #1b2a21;
    color: #e6f4ea;
}

QDialogButtonBox QPushButton {
    min-width: 80px;
}
/*Theme End*/
